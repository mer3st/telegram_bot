# ─── Required ─────────────────────────────────────────────────────────────────
BOT_TOKEN=                    # Telegram Bot token from @BotFather
GOOGLE_SHEET_ID=              # Spreadsheet ID from the Google Sheets URL
ADMIN_IDS=                    # Comma-separated Telegram user IDs, e.g. 123456789,987654321

# ─── Google Credentials ───────────────────────────────────────────────────────
# Option A (Railway / production): paste the full service-account JSON as one line
GOOGLE_CREDENTIALS=
# Option B (local dev): leave GOOGLE_CREDENTIALS empty and place credentials.json next to bot.py

# ─── Optional ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=               # Google Gemini API key for AI homework grading
FORM_URL=                     # Google Form URL with {} placeholder for the registration code

# ─── Telegram Channels ────────────────────────────────────────────────────────
BITO_CHANNEL_ID=              # Channel ID (negative number), e.g. -1001234567890
BI_CHANNEL_ID=                # Channel ID for the BI channel
BITO_CHANNEL_LINK=            # Public invite link shown to new BITO students
BI_CHANNEL_LINK=              # Public invite link shown to new BI students
